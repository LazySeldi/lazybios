# Doxygen configuration for lazybios.
# Run from the repository root with: doxygen Doxyfile

# Project metadata
PROJECT_NAME           = "lazybios"
PROJECT_NUMBER         =
PROJECT_BRIEF          = "Lightweight SMBIOS/DMI parsing library"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

# Input and path handling
INPUT                  = include \
                         src \
                         mainpage.md \
                         doc \
                         CONTRIBUTING.md \
                         ISSUES.md
FILE_PATTERNS          = *.h \
                         *.c \
                         *.dox \
                         *.md
RECURSIVE              = YES
EXCLUDE                = test \
                         build \
                         docs \
                         doc/examples \
                         README.md
EXCLUDE_SYMLINKS       = YES
EXCLUDE_PATTERNS       = */test/* \
                         */build/* \
                         */cmake-build-*/* \
                         */docs/* \
                         */doc/examples/*
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
USE_MDFILE_AS_MAINPAGE = mainpage.md

# Reusable source examples included by the Doxygen guide pages
EXAMPLE_PATH           = doc/examples
EXAMPLE_PATTERNS       = *.c
EXAMPLE_RECURSIVE      = NO

# C parsing and documentation behavior
OPTIMIZE_OUTPUT_FOR_C  = YES
MARKDOWN_SUPPORT       = YES
MARKDOWN_STRICT        = YES
MARKDOWN_ID_STYLE      = GITHUB
TOC_INCLUDE_HEADINGS   = 6
AUTOLINK_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = NO
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
TYPEDEF_HIDES_STRUCT   = YES

# Full API reference extraction
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_PRIV_VIRTUAL   = YES
EXTRACT_PACKAGE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES
INTERNAL_DOCS          = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_IN_BODY_DOCS      = NO
SHOW_INCLUDE_FILES     = YES
SHOW_GROUPED_MEMB_INC  = YES
INLINE_INFO            = YES

# Reference organization
ALPHABETICAL_INDEX     = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_GROUP_NAMES       = YES
SORT_BY_SCOPE_NAME     = YES
GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST = YES

# Source and cross-reference views
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
REFERENCES_LINK_SOURCE = YES
VERBATIM_HEADERS       = YES

# Diagnostics
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_IF_UNDOC_ENUM_VAL = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS
WARN_LOGFILE           = docs/doxygen-warnings.log

# HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_DYNAMIC_MENUS     = YES
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
ENUM_VALUES_PER_LINE   = 4

# Structured output for Markdown conversion.
# Doxygen parses Markdown but does not generate Markdown directly. The XML in
# docs/xml can be converted with a Doxygen XML-to-Markdown tool such as Moxygen.
GENERATE_XML           = YES
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = YES

# Disable unrequested output formats
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_DOCBOOK       = NO

# Diagrams remain dependency-free; set HAVE_DOT to YES when Graphviz is present.
HAVE_DOT               = NO
